  "/api/runs": {
    "get": {
      "description": "Returns paginated list of all kaseki runs, newest first. Includes basic metadata for each run.",
      "operationId": "listRuns",
      "parameters": [
        {
          "description": "Maximum number of runs to return",
          "in": "query",
          "name": "limit",
          "schema": {
            "default": 50,
            "maximum": 500,
            "minimum": 1,
            "type": "integer",
          },
        },
        {
          "description": "Offset for pagination",
          "in": "query",
          "name": "offset",
          "schema": {
            "default": 0,
            "minimum": 0,
            "type": "integer",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "runs": {
                    "items": {
                      "properties": {
                        "cached": {
                          "description": "True when returned from idempotency replay",
                          "type": "boolean",
                        },
                        "completedAt": {
                          "description": "ISO 8601 timestamp when the job completed",
                          "format": "date-time",
                          "type": "string",
                        },
                        "correlationId": {
                          "description": "Request correlation ID for tracing",
                          "type": "string",
                        },
                        "createdAt": {
                          "description": "ISO 8601 timestamp when the job was created",
                          "format": "date-time",
                          "type": "string",
                        },
                        "error": {
                          "description": "Error message if the job failed",
                          "type": "string",
                        },
                        "exitCode": {
                          "description": "Exit code from kaseki execution",
                          "type": "integer",
                        },
                        "failureClass": {
                          "description": "Classification of failure (e.g., validation_failed, timeout)",
                          "type": "string",
                        },
                        "id": {
                          "description": "Unique kaseki instance ID (kaseki-N)",
                          "example": "kaseki-42",
                          "type": "string",
                        },
                        "requestId": {
                          "description": "Unique request ID",
                          "type": "string",
                        },
                        "status": {
                          "description": "Current job status",
                          "enum": [
                            "queued",
                            "running",
                            "completed",
                            "failed",
                          ],
                          "type": "string",
                        },
                      },
                      "required": [
                        "id",
                        "status",
                        "createdAt",
                      ],
                      "type": "object",
                    },
                    "type": "array",
                  },
                  "total": {
                    "description": "Total number of runs available",
                    "type": "integer",
                  },
                },
                "required": [
                  "runs",
                  "total",
                ],
                "type": "object",
              },
            },
          },
          "description": "List of runs",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "List all runs",
      "tags": [
        "Run Management",
      ],
    },
    "post": {
      "description": "Submits a new job to the queue. Returns 202 Accepted with job metadata. Use the ID to poll status.",
      "operationId": "triggerRun",
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "properties": {
                "changedFilesAllowlist": {
                  "description": "File patterns to allow changes in",
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "idempotencyKey": {
                  "description": "Idempotency key for safe retries",
                  "format": "uuid",
                  "type": "string",
                },
                "maxDiffBytes": {
                  "description": "Max diff size in bytes",
                  "type": "integer",
                },
                "publishMode": {
                  "description": "Publishing mode after validation: pr creates a normal pull request (controller default when omitted), draft_pr creates a draft pull request, branch pushes only, auto publishes when credentials are available and skips if missing, none skips publishing",
                  "enum": [
                    "auto",
                    "none",
                    "branch",
                    "pr",
                    "draft_pr",
                  ],
                  "type": "string",
                },
                "ref": {
                  "default": "main",
                  "description": "Git branch/tag/commit",
                  "type": "string",
                },
                "repoUrl": {
                  "description": "Git repository URL",
                  "format": "uri",
                  "type": "string",
                },
                "startupCheck": {
                  "description": "Start a worker container and exit after boot checks",
                  "type": "boolean",
                },
                "startupCheckMode": {
                  "description": "Startup check depth: boot-only container smoke test or baseline validation dry-run",
                  "enum": [
                    "boot",
                    "baseline-validation",
                  ],
                  "type": "string",
                },
                "taskMode": {
                  "description": "Task mode",
                  "enum": [
                    "patch",
                    "inspect",
                  ],
                  "type": "string",
                },
                "taskPrompt": {
                  "description": "Task prompt for Pi agent",
                  "type": "string",
                },
                "timeoutSeconds": {
                  "description": "Per-run timeout in seconds",
                  "maximum": 10800,
                  "minimum": 60,
                  "type": "integer",
                },
                "tracing": {
                  "description": "Request tracing identifiers",
                  "type": "object",
                },
                "validationCommands": {
                  "description": "Validation commands to run",
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "webhookConfig": {
                  "description": "Webhook configuration for job events",
                  "type": "object",
                },
              },
              "required": [
                "repoUrl",
              ],
              "type": "object",
            },
          },
        },
        "required": true,
      },
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "cached": {
                    "description": "True when returned from idempotency replay",
                    "type": "boolean",
                  },
                  "completedAt": {
                    "description": "ISO 8601 timestamp when the job completed",
                    "format": "date-time",
                    "type": "string",
                  },
                  "correlationId": {
                    "description": "Request correlation ID for tracing",
                    "type": "string",
                  },
                  "createdAt": {
                    "description": "ISO 8601 timestamp when the job was created",
                    "format": "date-time",
                    "type": "string",
                  },
                  "error": {
                    "description": "Error message if the job failed",
                    "type": "string",
                  },
                  "exitCode": {
                    "description": "Exit code from kaseki execution",
                    "type": "integer",
                  },
                  "failureClass": {
                    "description": "Classification of failure (e.g., validation_failed, timeout)",
                    "type": "string",
                  },
                  "id": {
                    "description": "Unique kaseki instance ID (kaseki-N)",
                    "example": "kaseki-42",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Unique request ID",
                    "type": "string",
                  },
                  "status": {
                    "description": "Current job status",
                    "enum": [
                      "queued",
                      "running",
                      "completed",
                      "failed",
                    ],
                    "type": "string",
                  },
                },
                "required": [
                  "id",
                  "status",
                  "createdAt",
                ],
                "type": "object",
              },
            },
          },
          "description": "Idempotency replay: job already exists with same configuration",
        },
        "202": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "cached": {
                    "description": "True when returned from idempotency replay",
                    "type": "boolean",
                  },
                  "completedAt": {
                    "description": "ISO 8601 timestamp when the job completed",
                    "format": "date-time",
                    "type": "string",
                  },
                  "correlationId": {
                    "description": "Request correlation ID for tracing",
                    "type": "string",
                  },
                  "createdAt": {
                    "description": "ISO 8601 timestamp when the job was created",
                    "format": "date-time",
                    "type": "string",
                  },
                  "error": {
                    "description": "Error message if the job failed",
                    "type": "string",
                  },
                  "exitCode": {
                    "description": "Exit code from kaseki execution",
                    "type": "integer",
                  },
                  "failureClass": {
                    "description": "Classification of failure (e.g., validation_failed, timeout)",
                    "type": "string",
                  },
                  "id": {
                    "description": "Unique kaseki instance ID (kaseki-N)",
                    "example": "kaseki-42",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Unique request ID",
                    "type": "string",
                  },
                  "status": {
                    "description": "Current job status",
                    "enum": [
                      "queued",
                      "running",
                      "completed",
                      "failed",
                    ],
                    "type": "string",
                  },
                },
                "required": [
                  "id",
                  "status",
                  "createdAt",
                ],
                "type": "object",
              },
            },
          },
          "description": "Job accepted and queued",
        },
        "400": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Invalid request",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "Trigger a new kaseki run",
      "tags": [
        "Run Management",
      ],
    },
  },
  "/api/runs/{id}/analysis": {
    "get": {
      "description": "Returns a comprehensive post-run analysis including metadata, changes, validation results, and failure details.",
      "operationId": "getRunAnalysis",
      "parameters": [
        {
          "description": "Kaseki instance ID",
          "in": "path",
          "name": "id",
