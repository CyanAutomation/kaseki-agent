          "description": "Log type to retrieve",
          "in": "path",
          "name": "logtype",
          "required": true,
          "schema": {
            "enum": [
              "stdout",
              "stderr",
              "validation",
              "progress",
              "quality",
              "secret-scan",
            ],
            "type": "string",
          },
        },
        {
          "description": "Number of lines to tail (default: 100)",
          "in": "query",
          "name": "tail",
          "schema": {
            "default": 100,
            "minimum": 1,
            "type": "integer",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
              },
            },
          },
          "description": "Log content",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
        "404": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Run or log not found",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "Get specific log file",
      "tags": [
        "Run Logs & Progress",
      ],
    },
  },
  "/api/runs/{id}/progress": {
    "get": {
      "description": "Returns progress events for a run. Supports Server-Sent Events (SSE) streaming via \`?stream=sse\` query parameter.",
      "operationId": "getRunProgress",
      "parameters": [
        {
          "description": "Kaseki instance ID",
          "in": "path",
          "name": "id",
          "required": true,
          "schema": {
            "pattern": "^kaseki-\\d+$",
            "type": "string",
          },
        },
        {
          "description": "Set to "sse" to enable Server-Sent Events streaming",
          "in": "query",
          "name": "stream",
          "schema": {
            "enum": [
              "sse",
            ],
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/x-ndjson": {
              "schema": {
                "description": "Each line is a JSON progress event",
                "type": "object",
              },
            },
            "text/event-stream": {
              "schema": {
                "description": "Server-Sent Events format (when stream=sse)",
                "type": "object",
              },
            },
          },
          "description": "Progress events (JSONL or SSE format)",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
        "404": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Run not found",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "Get progress events",
      "tags": [
        "Run Logs & Progress",
      ],
    },
  },
  "/api/runs/{id}/status": {
    "get": {
      "description": "Returns current status of a kaseki run, including progress, elapsed time, and timeout risk percentage.",
      "operationId": "getRunStatus",
      "parameters": [
        {
          "description": "Kaseki instance ID (e.g., kaseki-42)",
          "in": "path",
          "name": "id",
          "required": true,
          "schema": {
            "pattern": "^kaseki-\\d+$",
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StatusResponse",
              },
            },
          },
          "description": "Current run status",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
        "404": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Run not found",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "Poll run status",
      "tags": [
        "Run Management",
      ],
    },
  },
  "/api/validate": {
    "post": {
      "description": "Validates the task configuration before submitting a run. Performs pre-flight checks on the task prompt and constraints.",
      "operationId": "validateTask",
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "properties": {
                "changedFilesAllowlist": {
                  "description": "File patterns to allow changes in",
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "idempotencyKey": {
                  "description": "Idempotency key for safe retries",
                  "format": "uuid",
                  "type": "string",
                },
                "maxDiffBytes": {
                  "description": "Max diff size in bytes",
                  "type": "integer",
                },
                "publishMode": {
                  "description": "Publishing mode after validation: pr creates a normal pull request (controller default when omitted), draft_pr creates a draft pull request, branch pushes only, auto publishes when credentials are available and skips if missing, none skips publishing",
                  "enum": [
                    "auto",
                    "none",
                    "branch",
                    "pr",
                    "draft_pr",
                  ],
                  "type": "string",
                },
                "ref": {
                  "default": "main",
                  "description": "Git branch/tag/commit",
                  "type": "string",
                },
                "repoUrl": {
                  "description": "Git repository URL",
                  "format": "uri",
                  "type": "string",
                },
                "startupCheck": {
                  "description": "Start a worker container and exit after boot checks",
                  "type": "boolean",
                },
                "startupCheckMode": {
                  "description": "Startup check depth: boot-only container smoke test or baseline validation dry-run",
                  "enum": [
                    "boot",
                    "baseline-validation",
                  ],
                  "type": "string",
                },
                "taskMode": {
                  "description": "Task mode",
                  "enum": [
                    "patch",
                    "inspect",
                  ],
                  "type": "string",
                },
                "taskPrompt": {
                  "description": "Task prompt for Pi agent",
                  "type": "string",
                },
                "timeoutSeconds": {
                  "description": "Per-run timeout in seconds",
                  "maximum": 10800,
                  "minimum": 60,
                  "type": "integer",
                },
                "tracing": {
                  "description": "Request tracing identifiers",
                  "type": "object",
                },
                "validationCommands": {
                  "description": "Validation commands to run",
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "webhookConfig": {
                  "description": "Webhook configuration for job events",
                  "type": "object",
                },
              },
              "required": [
                "repoUrl",
              ],
              "type": "object",
            },
          },
        },
        "required": true,
      },
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "checks": {
                    "items": {
                      "type": "object",
                    },
                    "type": "array",
                  },
                  "errors": {
                    "items": {
                      "type": "string",
                    },
                    "type": "array",
                  },
                  "estimatedDurationSeconds": {
                    "type": "integer",
                  },
                  "isValid": {
                    "type": "boolean",
                  },
                  "warnings": {
                    "items": {
                      "type": "string",
                    },
                    "type": "array",
                  },
                },
                "type": "object",
              },
            },
          },
          "description": "Validation result",
        },
        "400": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Invalid request",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "Validate task configuration",
      "tags": [
        "Service Info",
      ],
    },
  },
  "/api/webhooks/test": {
    "post": {
      "description": "Tests a webhook configuration by sending a test event to the specified URL.",
      "operationId": "testWebhook",
      "requestBody": {
        "content": {
          "application/json": {
            "schema": {
              "properties": {
                "secret": {
                  "type": "string",
                },
                "url": {
                  "format": "uri",
                  "type": "string",
                },
              },
              "required": [
                "url",
              ],
              "type": "object",
            },
          },
        },
        "required": true,
      },
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "message": {
                    "type": "string",
                  },
                  "statusCode": {
                    "type": "integer",
                  },
                  "success": {
                    "type": "boolean",
                  },
                },
                "type": "object",
              },
            },
          },
          "description": "Webhook test successful",
        },
        "400": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Invalid webhook configuration",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "Test webhook configuration",
      "tags": [
        "Webhooks",
      ],
    },
  },
  "/health": {
    "get": {
      "description": "Returns 200 OK if the service is running. No authentication required.",
      "operationId": "getHealth",
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "status": {
                    "enum": [
                      "ok",
                    ],
                    "type": "string",
                  },
                },
                "type": "object",
              },
            },
          },
          "description": "Service is healthy",
        },
      },
      "summary": "Health check endpoint",
      "tags": [
        "Health & Status",
      ],
    },
  },
  "/ready": {
    "get": {
      "description": "Returns 200 OK when the service is ready to accept requests. Checks queue and scheduler dependencies. No authentication required.",
      "operationId": "getReady",
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "message": {
                    "type": "string",
                  },
                  "ready": {
                    "type": "boolean",
                  },
                },
                "type": "object",
              },
            },
          },
          "description": "Service is ready",
        },
        "503": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Service is not ready",
        },
      },
      "summary": "Readiness probe",
      "tags": [
        "Health & Status",
      ],
    },
  },
}
`;
