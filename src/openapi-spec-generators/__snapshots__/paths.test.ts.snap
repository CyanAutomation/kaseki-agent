                        "type": "array",
                      },
                      "diffSize": {
                        "type": "integer",
                      },
                    },
                    "type": "object",
                  },
                  "completedAt": {
                    "format": "date-time",
                    "type": "string",
                  },
                  "createdAt": {
                    "format": "date-time",
                    "type": "string",
                  },
                  "elapsedSeconds": {
                    "type": "number",
                  },
                  "errors": {
                    "items": {
                      "type": "string",
                    },
                    "type": "array",
                  },
                  "exitCode": {
                    "type": "integer",
                  },
                  "failureClass": {
                    "type": "string",
                  },
                  "id": {
                    "type": "string",
                  },
                  "metadata": {
                    "type": "object",
                  },
                  "status": {
                    "enum": [
                      "queued",
                      "running",
                      "completed",
                      "failed",
                    ],
                    "type": "string",
                  },
                  "validation": {
                    "properties": {
                      "commandResults": {
                        "items": {
                          "type": "object",
                        },
                        "type": "array",
                      },
                      "passed": {
                        "type": "boolean",
                      },
                    },
                    "type": "object",
                  },
                },
                "required": [
                  "id",
                  "status",
                ],
                "type": "object",
              },
            },
          },
          "description": "Run analysis",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Unauthorized",
        },
        "404": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "error": {
                    "description": "Error message",
                    "type": "string",
                  },
                  "requestId": {
                    "description": "Request ID for debugging",
                    "type": "string",
                  },
                },
                "required": [
                  "error",
                ],
                "type": "object",
              },
            },
          },
          "description": "Run not found",
        },
      },
      "security": [
        {
          "BearerAuth": [],
        },
      ],
      "summary": "Get comprehensive run analysis",
      "tags": [
        "Run Details",
      ],
    },
  },
  "/api/runs/{id}/artifacts": {
