{
  "name": "kaseki-agent",
  "version": "0.1.0",
  "description": "Ephemeral coding-agent runner with Pi CLI and OpenRouter",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc && node dist/add-js-extensions.js && chmod 0755 dist/*.js",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint",
    "test": "npm run test:unit",
    "test:unit": "jest --passWithNoTests",
    "test:ci": "npm run build && npm run type-check && jest --passWithNoTests && bash run-kaseki-json.test.sh && bash tests/allowlist-glob.test.sh && bash tests/dependency-cache-key.test.sh && bash tests/dependency-restore-mode.test.sh && bash tests/npm-install-flags.test.sh && bash tests/repo-memory.test.sh && bash scripts/test-github-app.sh",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "npm run lint:js && npm run lint:sh || true",
    "lint:js": "eslint . src/ --ignore-pattern dist/",
    "lint:js:fix": "eslint . src/ --fix --ignore-pattern dist/",
    "lint:sh": "shellcheck run-kaseki.sh kaseki-agent.sh scripts/*.sh run-kaseki-json.test.sh",
    "lint:fix": "npm run lint:js:fix && npm run lint:sh",
    "kaseki-api": "tsx src/kaseki-api-service.ts",
    "type-check:full": "npm run type-check",
    "type-check:changed": "tsc --noEmit -p tsconfig.changed.json",
    "benchmark:pi-event-filter": "npm run build && RUN_PI_EVENT_FILTER_PERF=1 jest --testMatch \"<rootDir>/perf/**/*.benchmark.test.ts\" --runInBand",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "dependencies": {
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
