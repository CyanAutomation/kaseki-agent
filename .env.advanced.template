# Kaseki Agent Advanced Configuration
# 
# This template contains optional and advanced variables.
# Only uncomment/modify variables you want to customize.
# All variables have intelligent defaults.
#
# For Essential 8 variables and quick start, see: .env (or .env.template)

# === VALIDATION & QUALITY GATES ZONE ===

# File patterns agent is allowed to modify (space-separated glob patterns)
# Examples:
#   src/**                  (only src directory)
#   src/** tests/**         (src and tests)
#   lib/** *.json           (lib directory and JSON files)
# KASEKI_CHANGED_FILES_ALLOWLIST=src/**

# File patterns to check during post-agent validation
# Overrides KASEKI_CHANGED_FILES_ALLOWLIST if set
# KASEKI_VALIDATION_ALLOWLIST=src/** tests/**

# Restore files outside allowlist before validation (safety default)
# Default: true
# KASEKI_RESTORE_DISALLOWED_CHANGES=true

# Skip missing npm scripts instead of failing validation
# Default: true (non-fatal missing scripts)
# KASEKI_VALIDATION_ALLOW_MISSING_SCRIPTS=true

# === GOAL-SETTING AGENT ZONE ===

# Enable goal-setting agent (runs before scouting)
# Default: true (enabled)
# Set to false to disable goal-setting phase
# KASEKI_GOAL_SETTING=true

# Goal-setting agent model (optional override)
# Default: same as scouting model (KASEKI_SCOUTING_MODEL)
# KASEKI_GOAL_SETTING_MODEL=gpt-4-turbo

# Goal-setting agent timeout (seconds)
# Default: same as scouting timeout (KASEKI_SCOUTING_TIMEOUT_SECONDS)
# Recommended: 300-600 seconds (goal-setting is fast, read-only phase)
# KASEKI_GOAL_SETTING_TIMEOUT_SECONDS=300

# === CACHING & PERFORMANCE ZONE ===

# Enable dependency caching (4-layer npm cache strategy)
# Default: true (recommended)
# Set to false to disable caching entirely
# KASEKI_CACHE_ENABLED=true

# Dependency cache directory
# Default: $HOME/.kaseki/cache
# Must have sufficient disk space for large projects
# KASEKI_DEPENDENCY_CACHE_DIR=${HOME}/.kaseki/cache

# Git caching mode (off, mirror)
# Default: mirror (recommended)
# mirror: Clone repo once, use mirror for subsequent runs (faster)
# off: Fresh clone every time (slower but guaranteed fresh)
# KASEKI_GIT_CACHE_MODE=mirror

# Restore npm dependencies mode (copy, link)
# Default: copy (safest)
# copy: Copy from cache (disk intensive but isolated)
# link: Hard link from cache (faster, but shared state)
# KASEKI_DEPENDENCY_RESTORE_MODE=copy

# Skip install scripts during npm install
# Default: false
# Set to true to speed up npm ci (but scripts may not run)
# KASEKI_INSTALL_IGNORE_SCRIPTS=false

# Omit dev dependencies during npm install
# Default: false
# Set to true for production agent runs only
# KASEKI_NPM_OMIT_DEV=false

# === LOGGING & DEBUGGING ZONE ===

# Keep raw Pi JSONL events (for debugging)
# Default: false
# Set to true to preserve raw agent events for analysis
# KASEKI_DEBUG_RAW_EVENTS=false

# Host-level log directory (production API service only)
# Default: /var/log/kaseki
# Must be writable by container (UID 10000)
# KASEKI_LOG_DIR=/var/log/kaseki

# API service log level
# Options: debug, info, warn, error
# Default: info
# KASEKI_API_LOG_LEVEL=info

# === MONITORING & OBSERVABILITY ZONE ===

# Sentry DSN for error tracking (optional but recommended for production)
# See: docs/SENTRY_INTEGRATION.md for setup instructions
# Default: (not set - monitoring disabled)
# Get your DSN at: https://sentry.io (create Node.js project)
# SENTRY_DSN=https://key@o1234567890.ingest.sentry.io/9876543210

# Sentry environment label
# Options: development, staging, production (or custom)
# Default: production (assumes production unless overridden)
# SENTRY_ENVIRONMENT=development  # Set to development for local debugging

# Sentry release version
# Links errors to specific kaseki-agent versions
# Default: Auto-detected from:
#   1. SENTRY_RELEASE environment variable (if set)
#   2. Git tag via: git describe --tags --always
#   3. Not set if Git is unavailable
# 
# The auto-detection helps track errors by deployment version.
# Override only if auto-detection doesn't work or for custom versioning:
# SENTRY_RELEASE=1.53.4
# 
# For GitHub Actions release workflows:
# SENTRY_RELEASE=${{ github.event.release.tag_name }}

# Sentry transaction sampling rate
# Reduces costs by sampling only a percentage of transactions
# Range: 0.0 (errors only) to 1.0 (all transactions)
# Default: 0.1 (10% - recommended for production)
# SENTRY_SAMPLE_RATE=0.1

# === EXECUTION & PUBLISHING ZONE ===

# How to publish agent results
# Default: off
# Options:
#   off          (no publishing, keep results local)
#   branch       (push changes to new branch)
#   pr           (create pull request with changes)
#   draft_pr     (create draft PR for review before merge)
# KASEKI_PUBLISH_MODE=off

# Target repository URL (for overriding default in command)
# REPO_URL=https://github.com/user/repo

# Git reference (branch, tag, or commit)
# GIT_REF=main

# Task prompt (what the agent should do)
# TASK_PROMPT=Fix all TypeScript errors

# === DOCKER & INFRASTRUCTURE ZONE ===

# Docker image to use for agent container
# Default: docker.io/cyanautomation/kaseki-agent:latest
# KASEKI_IMAGE=docker.io/cyanautomation/kaseki-agent:latest

# Keep workspace after run (default: cleanup)
# Default: false (cleanup workspace)
# Set to true for debugging failed runs
# KASEKI_KEEP_WORKSPACE=false

# Base directory for runs and results
# Default: /agents (must be writable by UID 10000)
# KASEKI_ROOT=/agents

# Container user (uid:gid)
# Default: 10000:10000
# KASEKI_CONTAINER_USER=10000:10000

# === DISK MANAGEMENT & RUN RETENTION ZONE ===

# Number of recent runs to retain
# Older runs are automatically cleaned up before each new run starts
# Default: 5 (keeps last 5 completed runs, deletes everything older)
# 
# Set to 0 to delete all runs before each new run (maximum cleanup)
# Set to 10+ for keeping more history/analysis
# 
# Example scenarios:
#   KASEKI_RETENTION_RUNS=1   (minimal disk: only keep current run)
#   KASEKI_RETENTION_RUNS=5   (balanced: keep last 5 runs, ~500MB per run)
#   KASEKI_RETENTION_RUNS=10  (archive: keep last 10 runs, ~1GB total)
#
# Cleaning up is non-blocking and transparent:
# - Happens automatically before each new run starts
# - Can be triggered manually with: kaseki-agent cleanup --force
# - Dry-run preview available: kaseki-agent cleanup --dry-run
# KASEKI_RETENTION_RUNS=5

# Results directory (for cleanup operations)
# Default: /agents/kaseki-results
# KASEKI_RESULTS_DIR=/agents/kaseki-results

# Cache directory (stale cache entries are cleaned up with runs)
# Default: /agents/kaseki-cache
# KASEKI_CACHE_DIR=/agents/kaseki-cache

# === API SERVICE CONFIGURATION (local-api, production-api only) ===

# API service port
# Default: 8080
# KASEKI_API_PORT=8080

# API service base URL (for external access)
# Default: http://localhost:8080
# KASEKI_API_BASE_URL=http://localhost:8080

# Maximum concurrent agent runs
# Default: 3 (production), 2 (local)
# Increase for powerful hardware, decrease for resource-constrained systems
# KASEKI_API_MAX_CONCURRENT_RUNS=3

# === GITHUB INTEGRATION ZONE ===

# Enable GitHub App for PR creation
# Default: false
# Requires: GITHUB_APP_ID, GITHUB_APP_PRIVATE_KEY_FILE
# GITHUB_APP_ENABLED=false

# GitHub App ID (from GitHub settings > Developer settings > GitHub Apps)
# Used by API service when spawning worker containers
# GITHUB_APP_ID=12345

# GitHub App Client ID
# Used by API service when spawning worker containers
# GITHUB_APP_CLIENT_ID=Iv1.abc123

# Host path to GitHub App private key (PEM format)
# Docker Compose will mount this to container's /run/secrets/github_app_private_key
# Default: /home/pi/secrets/github_app_private_key
# KASEKI_HOST_GITHUB_APP_PRIVATE_KEY=/path/to/github_app_private_key.pem

# Host path to GitHub App ID secret file
# Docker Compose will mount this to container's /run/secrets/github_app_id
# Default: /home/pi/secrets/github_app_id
# KASEKI_HOST_GITHUB_APP_ID=/path/to/github_app_id

# Host path to GitHub App Client ID secret file
# Docker Compose will mount this to container's /run/secrets/github_app_client_id
# Default: /home/pi/secrets/github_app_client_id
# KASEKI_HOST_GITHUB_APP_CLIENT_ID=/path/to/github_app_client_id

# === ADVANCED & EXPERIMENTAL ZONE ===

# Dry-run mode (validate setup without running agent)
# Default: false
# Set to true to test configuration without execution
# KASEKI_DRY_RUN=false

# Repository memory mode
# Options: off, read, read-write
# Default: off
# Experimental: Store repository context between runs
# KASEKI_REPO_MEMORY_MODE=off

# Repository memory TTL (days)
# KASEKI_REPO_MEMORY_TTL_DAYS=30

# Repository memory max size (bytes)
# KASEKI_REPO_MEMORY_MAX_BYTES=1000000

# Startup check mode
# Options: boot (on service start), verify (before each run)
# Default: boot
# KASEKI_STARTUP_CHECK_MODE=boot

