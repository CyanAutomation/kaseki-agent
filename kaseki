#!/usr/bin/env bash
# 
# kaseki — Kaseki Agent convenience wrapper
#
# Supports two modes:
#   1. CLI operations: ./kaseki list, ./kaseki watch, ./kaseki status (runs kaseki-cli.js)
#   2. Container operations: ./kaseki setup, ./kaseki agent, ./kaseki run-mode, etc.

set -euo pipefail

# Configuration
ROOT="${KASEKI_ROOT:-/agents}"
TEMPLATE_DIR="${KASEKI_TEMPLATE_DIR:-/agents/kaseki-template}"
IMAGE="${KASEKI_IMAGE:-docker.io/cyanautomation/kaseki-agent:latest}"
SECRETS_DIR="${HOME}/.kaseki/secrets"
RESULTS_DIR="${KASEKI_RESULTS_DIR:-.}/results"

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Error: Docker is required for '$COMMAND' but is not installed" >&2
    echo "Run './kaseki detect' to see which commands are available on this host." >&2
    exit 2
  fi
}

show_detect() {
  local docker_status template_status agents_status secrets_status results_status recommendation

  if command -v docker >/dev/null 2>&1; then
    if docker info >/dev/null 2>&1; then
      docker_status="available and running"
    else
      docker_status="installed but daemon is not reachable"
    fi
  else
    docker_status="not installed"
  fi

  if [ -d "$ROOT" ]; then
    agents_status="present: $ROOT"
  else
    agents_status="missing: $ROOT"
  fi

  if [ -d "$TEMPLATE_DIR" ]; then
    template_status="present: $TEMPLATE_DIR"
  else
    template_status="missing: $TEMPLATE_DIR"
  fi

  if [ -d "$SECRETS_DIR" ]; then
    secrets_status="present: $SECRETS_DIR"
  else
    secrets_status="missing: $SECRETS_DIR"
  fi

  if [ -d "$RESULTS_DIR" ]; then
    results_status="present: $RESULTS_DIR"
  else
    results_status="will be created when needed: $RESULTS_DIR"
  fi

  recommendation="Run './kaseki setup' first."
  if [ "$template_status" = "present: $TEMPLATE_DIR" ]; then
    recommendation="Use CLI operations such as './kaseki list' or './kaseki watch <instance>' for existing /agents runs."
  elif [ "$docker_status" = "available and running" ]; then
    recommendation="Use container operations such as './kaseki setup' or './kaseki agent <repo> <ref>'."
  fi

  cat <<EOF
Kaseki environment detection

Docker:        $docker_status
/agents:       $agents_status
Template:      $template_status
Secrets:       $secrets_status
Results:       $results_status

Recommended next step:
  $recommendation

Mode guide:
  Container operations run through Docker and are best for setup and new tasks.
  CLI operations inspect existing instances and require $TEMPLATE_DIR.
EOF
}

# Help text
show_help() {
  cat <<EOF
kaseki — Kaseki Agent Command-Line Interface

CONTAINER OPERATIONS (new, easier interface):
  ./kaseki detect                           Show local setup and recommended mode
  ./kaseki setup [--help]                   Interactive setup wizard
  ./kaseki doctor [--help]                  Health check
  ./kaseki agent <repo> <ref> [--help]      Run agent task
  ./kaseki run-mode <repo> <ref>            One-command run (needs LLM_GATEWAY_API_KEY)
  ./kaseki setup-remote <host> <key>        Remote host setup

CLI OPERATIONS (instance monitoring, requires /agents directory):
  ./kaseki list                             List all instances
  ./kaseki status <instance>                Get instance status
  ./kaseki errors <instance>                Show errors for instance
  ./kaseki analysis <instance>              Get post-run analysis
  ./kaseki watch <instance> [--interval=2] Live monitor with anomaly detection
  ./kaseki follow <instance>                Stream logs in real-time
  ./kaseki progress <instance> [--tail=25] Show progress events

Environment Variables:
  KASEKI_IMAGE                      Docker image (default: docker.io/cyanautomation/kaseki-agent:latest)
  LLM_GATEWAY_URL                   LLM Gateway endpoint (required)
  LLM_GATEWAY_API_KEY               LLM Gateway API key (for run-mode)
  KASEKI_RESULTS_DIR                Results directory (default: ./results)

Examples:
  # Container: one-time setup
  ./kaseki detect
  ./kaseki setup
  
  # Container: run a task
  ./kaseki agent https://github.com/org/repo main
  
  # Container: one-command run (no setup needed)
  LLM_GATEWAY_URL=https://llmgateway.local.xyz/v1 LLM_GATEWAY_API_KEY=... ./kaseki run-mode https://github.com/org/repo main
  
  # CLI: monitor running instance
  ./kaseki watch kaseki-1 --interval=2

For detailed help:
  https://github.com/CyanAutomation/kaseki-agent/docs/DOCKER_SETUP.md (container ops)
  https://github.com/CyanAutomation/kaseki-agent/docs/CLI.md (CLI ops)

EOF
}

# Detect if command is a container operation or CLI operation
COMMAND="${1:-help}"

case "$COMMAND" in
  # Container operations
  setup|doctor|agent|run-mode|setup-remote)
    require_docker
    shift || true
    
    case "$COMMAND" in
      setup)
        mkdir -p "$SECRETS_DIR"
        chmod 700 "$SECRETS_DIR"
        
        docker run -it \
          --rm \
          -v /var/run/docker.sock:/var/run/docker.sock \
          -v "$SECRETS_DIR:/secrets" \
          "$IMAGE" \
          setup "$@"
        ;;
      
      doctor)
        docker run --rm \
          -v /var/run/docker.sock:/var/run/docker.sock \
          -v "$SECRETS_DIR:/secrets" \
          "$IMAGE" \
          doctor "$@"
        ;;
      
      agent)
        if [ ! -f "$SECRETS_DIR/llm_gateway_api_key" ]; then
          echo "Error: API key not found at $SECRETS_DIR/llm_gateway_api_key" >&2
          echo "Run setup first: ./kaseki setup"
          exit 1
        fi
        
        mkdir -p "$RESULTS_DIR"
        
        docker run -it \
          --rm \
          -v /var/run/docker.sock:/var/run/docker.sock \
          -v "$SECRETS_DIR:/secrets" \
          -v "$RESULTS_DIR:/results" \
          "$IMAGE" \
          agent "$@"
        ;;
      
      run-mode)
        if [ -z "${LLM_GATEWAY_API_KEY:-}" ] || [ -z "${LLM_GATEWAY_URL:-}" ]; then
          echo "Error: LLM_GATEWAY_API_KEY and LLM_GATEWAY_URL environment variables are required" >&2
          echo "Usage: LLM_GATEWAY_URL=<endpoint> LLM_GATEWAY_API_KEY=<key> ./kaseki run-mode <repo> <ref>"
          exit 1
        fi
        
        mkdir -p "$RESULTS_DIR"
        
        docker run -it \
          --rm \
          -e LLM_GATEWAY_URL \
          -e LLM_GATEWAY_API_KEY \
          -v /var/run/docker.sock:/var/run/docker.sock \
          -v "$RESULTS_DIR:/results" \
          "$IMAGE" \
          run-mode "$@"
        ;;
      
      setup-remote)
        if [ $# -lt 2 ]; then
          echo "Usage: ./kaseki setup-remote <host> <api-key-or-file>"
          exit 1
        fi
        
        docker run -it \
          --rm \
          "$IMAGE" \
          setup-remote "$@"
        ;;
    esac
    ;;
  
  # CLI operations (existing kaseki-cli.js wrapper)
  list|status|errors|analysis|watch|follow|progress)
    require_docker
    # Check if template directory exists (required for CLI)
    if [ ! -d "$TEMPLATE_DIR" ]; then
      echo "Error: Kaseki template directory not found: $TEMPLATE_DIR" >&2
      echo ""
      echo "CLI operations require /agents/kaseki-template to be set up."
      echo "For container operations (setup, agent, run-mode), use those directly."
      exit 2
    fi
    
    docker run --rm \
      --entrypoint node \
      -e KASEKI_RESULTS_DIR="$ROOT/kaseki-results" \
      -e KASEKI_RUNS_DIR="$ROOT/kaseki-runs" \
      -v "$TEMPLATE_DIR:/tools:ro" \
      -v "$ROOT:$ROOT:ro" \
      -w /tools \
      "$IMAGE" \
      /tools/kaseki-cli.js "$@"
    ;;
  
  detect)
    show_detect
    exit 0
    ;;

  --help|-h|help)
    show_help
    exit 0
    ;;
  
  *)
    echo "Error: Unknown command '$COMMAND'" >&2
    echo ""
    show_help
    exit 1
    ;;
esac
