# Kaseki Agent API Service - Environment Configuration Example
# 
# Copy this file to .env and update values for your deployment:
#   cp .env.example .env
#   # Edit .env with your actual values
#   docker-compose up -d
#
# SECURITY: Never commit .env to version control. Keep API keys and secrets safe.

# ===== REQUIRED =====

# OpenRouter API Key for Pi agent invocation
# Get from: https://openrouter.ai/keys
# SECURITY: Use a dedicated key, rotate regularly, never commit to git
OPENROUTER_API_KEY=sk-or-your-actual-api-key-here

# Comma-separated list of API keys for accessing kaseki-api service
# SECURITY: Use strong, unique keys. Use API key rotation in production.
KASEKI_API_KEYS=sk-your-secret-key-here

# ===== OPTIONAL: Docker Image Configuration =====

# Docker image to use for kaseki-agent containers
# Default: docker.io/cyanautomation/kaseki-agent:latest
# You can use a local build tag: kaseki-agent:node24-local
KASEKI_API_IMAGE=docker.io/cyanautomation/kaseki-agent:latest

# ===== OPTIONAL: API Service Configuration =====

# API service listen port
# Default: 8080
KASEKI_API_PORT=8080

# Log level for kaseki-api service
# Options: debug, info, warn, error
# Default: info
KASEKI_API_LOG_LEVEL=info

# Maximum concurrent kaseki-agent runs
# Adjust based on available system resources
# Default: 3
KASEKI_API_MAX_CONCURRENT_RUNS=3

# ===== OPTIONAL: Agent Execution Configuration =====

# Maximum time (in seconds) for a single Pi agent invocation
# Default: 1200 (20 minutes)
# Increase for larger codebases, decrease to fail fast
KASEKI_AGENT_TIMEOUT_SECONDS=1200

# Maximum allowed diff size in bytes
# Default: 200000 (200 KB)
# Prevents agents from making too many changes
KASEKI_MAX_DIFF_BYTES=200000

# ===== OPTIONAL: Container User Configuration =====

# Container user and group (UID:GID)
# IMPORTANT: Must match the Dockerfile build (UID 10000)
# Default: 10000:10000
KASEKI_CONTAINER_USER=10000:10000

# ===== OPTIONAL: Docker Socket Group =====

# Docker group ID on the host (for spawning worker containers)
# Get with: stat -c '%g' /var/run/docker.sock
# Default: 985 (common on Linux)
# On macOS/WSL, use the actual group ID from the socket
DOCKER_GID=985

# ===== OPTIONAL: User Configuration =====

# Container API user (if different from default)
# Default: 10000:10000
KASEKI_API_USER=10000:10000

# ===== OPTIONAL: GitHub App Authentication =====

# If using GitHub App for authenticated git operations (optional)
# Set these to enable GitHub App authentication

# GitHub App ID
# File path: GITHUB_APP_ID_FILE=/agents/secrets/github_app_id
# Or env var: GITHUB_APP_ID=your-app-id

# GitHub App Client ID
# File path: GITHUB_APP_CLIENT_ID_FILE=/agents/secrets/github_client_id
# Or env var: GITHUB_APP_CLIENT_ID=your-client-id

# GitHub App Private Key
# File path: GITHUB_APP_PRIVATE_KEY_FILE=/agents/secrets/github_app_private_key
# Or env var: GITHUB_APP_PRIVATE_KEY=your-private-key-pem
# SECURITY: Always use file paths for private keys, never inline in .env

# ===== SYSTEM DIRECTORIES =====

# These are usually set automatically, but can be overridden:

# Results directory (persists run artifacts)
# Default: /agents/kaseki-results
# KASEKI_RESULTS_DIR=/agents/kaseki-results

# API log directory
# Default: /var/log/kaseki-api
# KASEKI_API_LOG_DIR=/var/log/kaseki-api

# ===== DEPLOYMENT NOTES =====

# 1. Create /agents directory with proper permissions:
#    IMPORTANT: If running kaseki-agent with `sudo`, use world-writable permissions
#    because the host script runs as root and creates subdirectories that the
#    container (UID 10000) needs to write to.
#
#    sudo mkdir -p /agents
#    sudo chmod 777 /agents  # World-writable (required when using sudo)
#    
#    OR if running without sudo:
#    sudo mkdir -p /agents
#    sudo chown 10000:10000 /agents
#    sudo chmod 755 /agents

# 2. Set OpenRouter API key (required to run agents):
#    export OPENROUTER_API_KEY="sk-or-your-actual-key"
#    # Or add to this .env file

# 3. Ensure Docker socket is accessible:
#    export DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)

# 4. For production, use a reverse proxy (nginx) for HTTPS:
#    Listen on 443 (HTTPS) and proxy to localhost:8080

# 5. Set up log rotation if logging to files:
#    sudo cp ops/logrotate/kaseki-api /etc/logrotate.d/

# 6. Monitor API health:
#    curl -H "Authorization: Bearer $KASEKI_API_KEYS" http://localhost:8080/api/health
