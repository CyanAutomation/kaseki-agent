# Minimal secure Docker build context baseline

# --- Allowlist only what Dockerfile copies ---
**
!Dockerfile
!kaseki-agent.sh
!package.json
!package-lock.json
!tsconfig.json
!jest.config.js
!src/
!src/**
!dist/
!dist/**
!.dockerignore
!docker/
!docker/workspace-cache/
!docker/workspace-cache/package.json
!docker/workspace-cache/package-lock.json

# --- Common exclusions (explicit for clarity) ---
.git
.gitignore
node_modules
*.log
.env
.env.*
.DS_Store
.vscode
.idea
*.swp
*.swo

# Test / coverage artifacts
coverage
.nyc_output
*.lcov
junit*.xml

# Project-specific files not needed for image build
README.md
run-kaseki.sh
cleanup-kaseki.sh
CONTRIBUTING.md
STYLE.md
CLAUDE.md
CHANGELOG.md
.github/
