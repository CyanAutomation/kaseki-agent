# Minimal secure Docker build context baseline

# --- Allowlist only what Dockerfile copies ---
**
!Dockerfile
!kaseki
!kaseki-agent.sh
!run-kaseki.sh
!package.json
!package-lock.json
!tsconfig.json
!jest.config.js
!src/
!src/**
!.dockerignore
!README.md
!CLAUDE.md
!CONTRIBUTING.md
!STYLE.md
!docs/
!docs/**
!ops/
!ops/**
!scripts/
!scripts/**
!test/
!test/fixtures/
!test/fixtures/**
!docker/
!docker/workspace-cache/
!docker/workspace-cache/package.json
!docker/workspace-cache/package-lock.json

# --- Common exclusions (explicit for clarity) ---
.git
.gitignore
node_modules
*.log
.env
.env.*
.DS_Store
.vscode
.idea
*.swp
*.swo

# Test / coverage artifacts
coverage
.nyc_output
*.lcov
junit*.xml

.github/
dist/
