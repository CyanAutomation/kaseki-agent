# Minimal secure Docker build context baseline

# --- Allowlist only what Dockerfile copies ---
**
!Dockerfile
!kaseki-agent.sh
!lib/
!lib/pi-event-filter.js
!lib/pi-progress-stream.js
!lib/kaseki-report.js
!lib/github-app-token.js
!.dockerignore
!docker/
!docker/workspace-cache/
!docker/workspace-cache/package.json
!docker/workspace-cache/package-lock.json

# --- Common exclusions (explicit for clarity) ---
.git
.gitignore
node_modules
*.log
.env
.env.*
.DS_Store
.vscode
.idea
*.swp
*.swo

# Test / coverage artifacts
coverage
.nyc_output
*.lcov
junit*.xml

# Project-specific files not needed for image build
README.md
run-kaseki.sh
cleanup-kaseki.sh
