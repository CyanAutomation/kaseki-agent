# Kaseki Agent Configuration Template
# Generated by: kaseki-agent init
# 
# This template includes the Essential 8 variables needed for setup.
# All other variables have intelligent defaults and are optional.
# 
# For advanced configuration options, see: .env.advanced
#
# DOCKER COMPOSE USERS: Before running docker-compose up -d, ensure /agents 
# directory exists on the host with correct ownership:
#
#   sudo mkdir -p /agents
#   sudo chown 10000:10000 /agents
#   sudo chmod 755 /agents
#
# The container runs as UID 10000 (non-root). Without this ownership, startup
# checks will fail and the container will restart. See DEPLOYMENT.md for details.

# === ESSENTIAL 8 ===
# These variables are required or highly recommended

# OpenRouter API Key file path (mode 0600 - owner read/write only)
# Required for all execution paths
# Default: $HOME/.kaseki/secrets.json
OPENROUTER_API_KEY_FILE=${HOME}/.kaseki/secrets.json

# AI Model identifier
# Default: openrouter/free
# Options: openrouter/free, openrouter/openai/gpt-4-turbo, openrouter/anthropic/claude-3-opus
KASEKI_MODEL=openrouter/free

# Validation Commands (semicolon-separated)
# Commands to run after agent completes to validate changes
# Default: npm run check;npm run test;npm run build
# Examples for other languages:
#   Python: pytest;mypy .
#   Rust: cargo test;cargo fmt --check
#   Go: go test ./...;go fmt ./...
KASEKI_VALIDATION_COMMANDS=npm run check;npm run test;npm run build

# Pre-agent Validation
# Run validation commands before agent runs (checks baseline state)
# Default: false
KASEKI_PRE_AGENT_VALIDATION=false

# Agent Timeout (seconds)
# Maximum time agent can run
# Default: 10800 (3 hours - for long-running agentic tasks)
# Increase for extra-large codebases: 14400 (4 hours)
KASEKI_AGENT_TIMEOUT_SECONDS=10800

# GitHub PR Publish Mode
# How to publish changes when GitHub credentials are available
# Default: pr (create a normal pull request)
# Options: pr (normal PR), draft_pr (draft PR for review), branch (push without PR), none (skip GitHub)
# Note: Requires GITHUB_APP_PRIVATE_KEY_FILE and other GitHub App credentials
KASEKI_PUBLISH_MODE=pr

# Maximum Diff Size (bytes)
# Quality gate: fail if changes exceed this size
# Default: 400000 (400 KB - for large refactors)
# Increase for extra-large changes: 1000000 (1 MB)
KASEKI_MAX_DIFF_BYTES=400000

# Stream Progress
# Show sanitized progress lines to stdout
# Default: true (recommended)
# Set to false to reduce log noise in CI/CD
KASEKI_STREAM_PROGRESS=true

# === API SERVICE ONLY ===
# These variables are only used for local or production API service

# API Service Authentication Keys
# Comma or newline-separated bearer tokens
# Auto-generated during setup if not provided
# Format: sk-xxx,sk-yyy or one per line
# KASEKI_API_KEYS=sk-your-key-here

# === OPTIONAL: Common Customizations ===
# Uncomment and modify as needed

# File patterns the agent is allowed to modify
# Examples:
#   KASEKI_CHANGED_FILES_ALLOWLIST=src/**
#   KASEKI_CHANGED_FILES_ALLOWLIST=src/** tests/** *.json
# KASEKI_CHANGED_FILES_ALLOWLIST=src/**

# Restore files outside allowlist before validation (safety default)
# KASEKI_RESTORE_DISALLOWED_CHANGES=true

# Enable dependency caching (4-layer cache strategy)
# KASEKI_CACHE_ENABLED=true

# Dependency cache directory
# KASEKI_DEPENDENCY_CACHE_DIR=${HOME}/.kaseki/cache

